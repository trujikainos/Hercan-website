# Variables de entorno de la tienda Hercan.
# Local: copia a .env.local. Vercel: Settings → Environment Variables.
# NUNCA subir valores reales a git.

# ── Shopify (Storefront API) — obligatorio ──
# Dominio de tu tienda, ej: hercan.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Token público de la Storefront API
SHOPIFY_STOREFRONT_TOKEN=
# Token privado de la Storefront API (opcional, solo servidor, mejor límite; se prefiere si existe)
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=
# Versión de la Storefront API
SHOPIFY_API_VERSION=2026-07

# ── Sitio ──
# URL pública del deploy (staging .vercel.app o el dominio final):
NEXT_PUBLIC_SITE_URL=https://tu-proyecto.vercel.app
# 1 = staging (Google NO indexa). Quitar o =0 en producción para indexar:
NEXT_PUBLIC_NOINDEX=1
# Portal de cuentas de cliente de Shopify (opcional, tiene fallback):
NEXT_PUBLIC_SHOPIFY_ACCOUNT_URL=

# ── Cotización por email (Resend) ──
# API key de resend.com. Sin esto, el formulario cae a WhatsApp.
RESEND_API_KEY=
# Remitente verificado en Resend. Debe ser del subdominio verificado (notificaciones.hercan.com.mx).
# Ese subdominio NO recibe correo (solo envía), por eso se usa no-reply; las respuestas se enrutan
# con reply_to en el código (lead → cliente; confirmación → ventas@hercan.com.mx).
# Ej: HERCAN <no-reply@notificaciones.hercan.com.mx>
RESEND_FROM=
# Destino de los leads (a quién le llega la notificación). Default: leads@weevolveit.com
QUOTE_LEADS_TO=

# ── Medición (Fase 6, opcional/vacío hasta crear cuentas) ──
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── Admin API — da de alta cada cotización como Borrador de pedido en Shopify ──
# Token con scopes: write_draft_orders + read_products.
# Sin esto, la cotización funciona igual pero no se crea el borrador (solo el correo).
SHOPIFY_ADMIN_TOKEN=
# (Opcional) Dominio para el Admin API, si el token se emitió sobre un alias
# distinto al de Storefront. Ej: exv1fw-1e.myshopify.com
SHOPIFY_ADMIN_DOMAIN=

# Setup ÚNICO para obtener el SHOPIFY_ADMIN_TOKEN de arriba vía /api/shopify/install
# (OAuth). Son el "ID de cliente" y el "Secreto" de la app en el Dev Dashboard.
# Al terminar, ELIMINA SHOPIFY_APP_SECRET para apagar la página de instalación.
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_SECRET=

# Nota: sin SHOPIFY_STORE_DOMAIN + token, la tienda usa datos MOCK (src/lib/mock-data.ts).
